#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
CONTROLLER="$SCRIPT_DIR/../lib/safari-media-control.jxa.js"
LOG_FILE="${ALEXA_SAFARI_REMOTE_LOG:-$HOME/.local/state/alexa-safari-remote/commands.log}"

usage() {
  cat <<'EOF'
Usage:
  safari-remote toggle
  safari-remote play
  safari-remote pause
  safari-remote back [seconds]
  safari-remote forward [seconds]
  safari-remote seek <seconds|mm:ss|hh:mm:ss>
  safari-remote fullscreen
  safari-remote escape
  safari-remote selftest

Examples:
  safari-remote pause
  safari-remote back 10
  safari-remote forward 30
  safari-remote seek 12:34
EOF
}

to_seconds() {
  local input="${1:-}"
  local h m s

  if [[ -z "$input" ]]; then
    echo "Missing time value" >&2
    return 2
  fi

  input="${input//[[:space:]]/}"

  if [[ "$input" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$input"
    return 0
  fi

  if [[ "$input" =~ ^([0-9]+):([0-9]{1,2})$ ]]; then
    m="${BASH_REMATCH[1]}"
    s="${BASH_REMATCH[2]}"
    printf '%s\n' "$((10#$m * 60 + 10#$s))"
    return 0
  fi

  if [[ "$input" =~ ^([0-9]+):([0-9]{1,2}):([0-9]{1,2})$ ]]; then
    h="${BASH_REMATCH[1]}"
    m="${BASH_REMATCH[2]}"
    s="${BASH_REMATCH[3]}"
    printf '%s\n' "$((10#$h * 3600 + 10#$m * 60 + 10#$s))"
    return 0
  fi

  echo "Could not parse time: $input" >&2
  return 2
}

log_invocation() {
  local log_dir
  log_dir="$(dirname "$LOG_FILE")"
  mkdir -p "$log_dir" 2>/dev/null || return 0
  {
    printf '%s action=%q args=' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$action"
    printf '%q ' "$@"
    printf '\n'
  } >>"$LOG_FILE" 2>/dev/null || true
}

run_controller() {
  log_invocation "$@"
  osascript -l JavaScript "$CONTROLLER" "$@"
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

action="$1"
shift || true

case "$action" in
  toggle|playpause|play-pause)
    run_controller toggle
    ;;
  play)
    run_controller play
    ;;
  pause)
    run_controller pause
    ;;
  back|rewind)
    seconds="$(to_seconds "${1:-10}")"
    run_controller back "$seconds"
    ;;
  forward|ahead|skip)
    seconds="$(to_seconds "${1:-10}")"
    run_controller forward "$seconds"
    ;;
  seek|goto|jump)
    seconds="$(to_seconds "${1:-}")"
    run_controller seek "$seconds"
    ;;
  fullscreen|full-screen)
    run_controller fullscreen
    ;;
  escape|esc)
    run_controller escape
    ;;
  selftest)
    run_controller __selftest
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown action: $action" >&2
    usage >&2
    exit 2
    ;;
esac
