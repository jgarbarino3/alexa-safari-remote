[
  {
    "trigger": "Safari pause",
    "command": "$HOME/.local/bin/safari-remote pause",
    "ground": "foreground",
    "voice": "true",
    "voiceReply": "Paused Safari"
  },
  {
    "trigger": "Safari play",
